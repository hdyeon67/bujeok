# 행운부적 환경변수 예시. 실제 값은 .env.local / .env.production 에.

# ── 결제 ─────────────────────────────────────────────
# 사업자등록 전까지 false. 프리미엄 부적 버튼은 "오픈 준비 중" 잠금 배지로 노출.
PAYMENT_ENABLED=false

# ── 광고(애드센스) ───────────────────────────────────
# 애드센스 승인 전까지 false. 광고 슬롯 컴포넌트만 존재, 미노출.
NEXT_PUBLIC_ADS_ENABLED=false
NEXT_PUBLIC_ADSENSE_CLIENT=

# ── 카카오 공유 ──────────────────────────────────────
# 카카오 JS 키 미발급 상태. 값이 없으면 공유 버튼은 링크 복사·PNG 저장만 노출.
NEXT_PUBLIC_KAKAO_JS_KEY=

# ── 사이트 ───────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://bujeok.fineboll.com

# ── 계측 (analytics-spec.md) ─────────────────────────
# PostHog 프로젝트 키(쿠키리스 메인). 없으면 계측 비활성.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Cloudflare Web Analytics 토큰(보조). 없으면 비활성.
NEXT_PUBLIC_CF_BEACON_TOKEN=
